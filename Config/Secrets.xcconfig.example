// Secrets.xcconfig.example
//
// Copy this file to `Secrets.xcconfig` (same directory) and fill in real values.
// `Secrets.xcconfig` is gitignored — never commit it.
//
// CANVAS_FEED_URL:
//   Personal Canvas calendar feed URL. To find yours:
//     1. Log into Canvas (suffieldacademy.instructure.com)
//     2. Open Calendar
//     3. Click "Calendar Feed" in the right sidebar
//     4. Copy the URL
//
//   URLs contain "//" which xcconfig treats as a comment. Escape with $()
//   around each "//" as shown below (xcconfig's documented workaround).

CANVAS_FEED_URL = https:$()//suffieldacademy.instructure.com/feeds/calendars/user_EXAMPLETOKEN.ics
